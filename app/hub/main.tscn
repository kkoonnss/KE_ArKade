[node name="Text" type="RichTextLabel" parent="HelpOverlay/Panel/Margin/VBox"]
layout_mode = 2
size_flags_vertical = 3
theme_override_font_sizes/normal_font_size = 20
bbcode_enabled = true
text = "[b]1. Calibrate (Warping):[/b]
Launch the 4-Point Calibration tool to map your physical projector output onto the wall. This saves a calibration profile.

[b]2. Create a Scene (Environment):[/b]
A Scene represents a physical room. In the 'Scenes' tab, you can launch the Level Editor to trace/extract a map of your real-world room (like shelves and doors) using a background photo.

[b]3. Build a Level (Map):[/b]
Levels are designed on top of Scenes. The Level Editor generates all the paths and collision data for the games automatically.

[b]4. Play (Cartridges):[/b]
Select your Scene, select your Level, then pick a Cartridge from the Hub screen to play the game on your mapped wall!"

[node name="CloseHelpBtn" type="Button" parent="HelpOverlay/Panel/Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Got it"
